+/* ── INTRO ── */
+.intro {
+  position: relative;
+  height: 100vh;
+  min-height: 580px;
+  overflow: hidden;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  border-bottom: 1px solid var(--border);
+}
 
-  .nav-links a {
-    margin-left: 0;            /* remove left margin in stacked mode */
-    margin-right: 12px;        /* small horizontal spacing instead */
-  }
+.intro::after {
+  content: '';
+  position: absolute;
+  top: 35%;
+  left: 50%;
+  transform: translate(-50%, -50%);
+  width: 700px;
+  height: 500px;
+  background: radial-gradient(ellipse, rgba(96,165,250,0.1) 0%, rgba(129,140,248,0.05) 40%, transparent 70%);
+  pointer-events: none;
+  z-index: 1;
+}
+
+#bg { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; }
+
+.intro-inner {
+  position: relative;
+  z-index: 2;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  text-align: center;
+  padding: 24px;
+  gap: 6px;
+}
+
+/* Avatar with gradient ring */
+.avatar-wrapper {
+  position: relative;
+  margin-bottom: 22px;
+  display: inline-block;
+}
+.avatar-wrapper::before {
+  content: '';
+  position: absolute;
+  inset: -3px;
+  border-radius: 50%;
+  background: linear-gradient(135deg, #60a5fa, #818cf8, #c084fc);
+  z-index: 0;
+}
+.avatar {
+  display: block;
+  position: relative;
+  z-index: 1;
+  width: 156px;
+  height: 156px;
+  border-radius: 50%;
+  object-fit: cover;
+  border: 3px solid var(--bg);
+}
+
+.name {
+  font-size: clamp(30px, 5vw, 50px);
+  font-weight: 800;
+  letter-spacing: -0.025em;
+  line-height: 1.1;
+  background: linear-gradient(135deg, #e2e8f0 0%, #a5b4fc 60%, #c084fc 100%);
+  -webkit-background-clip: text;
+  -webkit-text-fill-color: transparent;
+  background-clip: text;
+  margin-bottom: 6px;
+}
+
+.role {
+  color: var(--muted);
+  font-size: 16px;
+  font-weight: 400;
+  letter-spacing: 0.02em;
+  margin-bottom: 22px;
+}
+
+.links { display: flex; gap: 10px; justify-content: center; }
+.icon {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: 46px;
+  height: 46px;
+  border-radius: 14px;
+  background: rgba(255,255,255,0.04);
+  border: 1px solid var(--border);
