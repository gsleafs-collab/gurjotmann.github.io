+  animation: bounce 2.2s ease-in-out infinite;
+  display: flex;
+  transition: color 0.2s;
+}
+.chevron:hover { color: var(--accent); }
+@keyframes bounce {
+  0%, 100% { transform: translateY(0); }
+  50%       { transform: translateY(7px); }
+}
